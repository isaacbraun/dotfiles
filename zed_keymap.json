    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "cmd-shift-e": "project_panel::ToggleFocus"
    }
  },
  {
    "bindings": {
      "alt-e": "project_panel::Toggle"
    }
  },
  {
    "bindings": {
