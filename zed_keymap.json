  {
    "context": "vim_mode == literal",
    "bindings": {
      "ctrl-f": null
    }
  },
  {
    "context": "(VimControl && !menu)",
    "bindings": {
      "ctrl-f": null
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-f": null
    }
  },
  {
    "context": "(Editor && (edit_prediction && (showing_completions || in_leading_whitespace)))",
    "bindings": {
      "alt-tab": null,
      "ctrl-alt-f": "editor::AcceptEditPrediction"
    }
  },
  {
    "context": "(Editor && edit_prediction)",
    "bindings": {
      "alt-tab": null
    }
  },
  {
    "context": "Editor && vim_mode == visual",
    "bindings": {
      "shift-j": "editor::MoveLineDown",
      "shift-k": "editor::MoveLineUp"
    }
  },
  {
    "context": "((os != macos && Editor) && (edit_prediction && (showing_completions || in_leading_whitespace)))",
    "bindings": {
      "alt-l": null
    }
  },
  {
    "context": "(Editor && edit_prediction)",
    "bindings": {
      "ctrl-f": "editor::AcceptEditPrediction"
    }
  },
  {
    "context": "(Editor && showing_completions)",
    "bindings": {
      "ctrl-y": "editor::ConfirmCompletion"
    }
  },
  {
    "context": "GitPanel",
    "bindings": {
      "ctrl-g p": "git::Push"
    }
  },
  {
    "context": "(!Editor && !Terminal)",
    "bindings": {
      "g /": "pane::DeploySearch"
    }
  },
  {
    "context": "(!Editor && !Terminal)",
    "bindings": {
      "space p s": "pane::DeploySearch"
    }
  },
  {
    "context": "(VimControl && !menu)",
    "bindings": {
      "g /": "pane::DeploySearch",
      "space p s": "pane::DeploySearch",
      "ctrl-shift-u": "vim::ScrollUp",
      "ctrl-shift-d": "vim::ScrollDown"
    }
  },
  {
    "context": "(Editor && showing_completions)",
    "bindings": {
      "enter": null
