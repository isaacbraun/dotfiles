    "context": "Workspace",
    "bindings": {
      "cmd-8": null
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-9": null
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "cmd-1": ["pane::ActivateItem", 0]
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "cmd-2": ["pane::ActivateItem", 1]
    }
  },
  {
    "context": "VimControl",
    "bindings": {
