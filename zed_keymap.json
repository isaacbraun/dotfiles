    "bindings": {
      "enter": null
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "cmd-g": null
    }
  },
  {
    "context": "ContextEditor > Editor",
    "bindings": {
      "cmd-g": null
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-shift-g": null
    }
  },
  {
    "bindings": {
      "ctrl-a f": "git::Worktree"
    }
  },
  {
    "context": "VimControl",
    "bindings": {
