[user]
  name = Isaac Braun
	email = isaac@braunbauen.com
	signingkey = ~/.ssh/id_signing_ed25519.pub

# Conditional identities
[includeIf "gitdir:~/dev/enterprise/"]
    path = ~/.gitconfig-enterprise

# Inital setup taken from Thorsten Ball's Config: https://github.com/mrnugget/dotfiles/blob/c4624ed521d539856bcf764f04a295bb19093566/gitconfig
[alias]
  b = branch
  bl = branch --list
  # Lists all branches including remote branches
  bla = branch -a
  c = commit
  sw = switch
  co = checkout
  cl = clone
  cp = cherry-pick
  st = status
  rh = reset HEAD
  rhh = reset --hard HEAD
  pu = push 
  pf = push --force-with-lease
  up = pull 
  bup = push -u origin HEAD

  # Push to origin and set upstream
  sync = !git pull --rebase && git push

  # Taken from here: https://aaronbonner.io/post/80766268890/git-alias-to-simplify-setting-upstream-branch
  sup = "!git branch --set-upstream-to=origin/`git symbolic-ref --short HEAD`"

  l = "!. ~/.githelpers && pretty_git_log"
  la = "!git l --all"
  lr = "!git l -30"
  lra = "!git lr --all"
  lg = "!git l -G $1 -- $2"
  feature = !sh -c 'git checkout --no-track -b $0 origin/main'

  ruf = "!. ~/.githelpers && remove_untracked_files"
	tree = log --oneline --decorate --graph

  # Taken from: https://haacked.com/archive/2025/04/17/git-gone/
  # Lists one-line commit summaries for the current branch (vs default branch)
  branchlog = "!f() { DEFAULT=$(git default); git --no-pager log --oneline $DEFAULT..HEAD; }; f"
  default = "!git symbolic-ref refs/remotes/origin/HEAD | sed 's@^refs/remotes/origin/@@'"
  # Prune remote-merged branches (gh poi), delete local merged branches and their worktrees,
  # then delete stranded local branches (ancestors of default with no upstream, no worktree).
  bclean = "!git gone | xargs -r git branch -D"
  # Switches to specified branch (or the default branch if no branch is specified), runs git up, then runs bclean.
  bdone = "!f() { DEFAULT=$(git default); git checkout ${1-$DEFAULT} && git pull && git bclean; }; f"
  gone = "!git for-each-ref --format='%(refname:short) %(upstream:track)' refs/heads/ | awk '$2 == \"[gone]\" { print $1 }'"

[core]
  excludesfile = ~/.gitignore
  pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true  # use n and N to move between diff sections

[merge]
    conflictStyle = zdiff3

[color]
  diff = auto
  status = auto
  branch = auto
	ui = true

[push]
	default = current
	followTags = true

[remote]
  pushDefault = origin

[branch]
	autosetuprebase = always

[diff "gpg"]
	binary = true
	textconv = gpg -d --quiet --yes --compress-algo=none --no-encrypt-to --batch --use-agent

[commit]
	verbose = true
	gpgsign = true
[init]
	defaultBranch = main
[pull]
	rebase = true
[protocol "file"]
  allow = always
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers
[fetch]
	prune = true
