// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "diff_view_style": "split",
  "window_decorations": "client",
  "use_system_window_tabs": false,
  "bottom_dock_layout": "contained",
  "preview_tabs": {
    "enabled": true
  },
  "title_bar": {
    "show_menus": false,
    "show_user_picture": false,
    "show_user_menu": true,
    "show_onboarding_banner": true,
    "show_sign_in": true,
    "show_project_items": true,
    "show_branch_name": true,
    "show_branch_icon": false
  },
  "search": {
    "button": false
  },
  "status_bar": {
    "cursor_position_button": true
  },
  "ui_font_weight": 400.0,
  "ui_font_family": ".ZedSans",
  "buffer_line_height": "comfortable",
  "ensure_final_newline_on_save": false,
  "remove_trailing_whitespace_on_save": false,
  "edit_predictions": {
    "provider": "copilot"
  },
  "sticky_scroll": {
    "enabled": true
  },
  "session": {
    "trust_all_worktrees": true
  },
  "colorize_brackets": true,
  "agent_servers": {
    "opencode": {
      "type": "extension",
      "default_model": "github-copilot/gpt-5"
    }
  },
  "use_autoclose": false,
  "use_auto_surround": true,
  "show_signature_help_after_edits": true,
  "debugger": {
    "button": false,
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "outline_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "project_panel": {
    "button": true,
    "default_width": 300.0,
    "dock": "right"
  },
  "terminal": {
    "toolbar": {
      "breadcrumbs": false
    },
    "cursor_shape": "block",
    "font_size": 17.0,
    "font_weight": 300.0,
    "button": false,
    "dock": "right"
  },
  "when_closing_with_no_tabs": "keep_window_open",
  "file_finder": {
    "modal_max_width": "large"
  },
  "vertical_scroll_margin": 0.0,
  "tabs": {
    "close_position": "right",
    "show_close_button": "hover",
    "file_icons": false,
    "git_status": true
  },
  "relative_line_numbers": "enabled",
  "diagnostics": {
    "button": true,
    "inline": {
      "enabled": true
    }
  },
  "agent": {
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "gpt-5.4",
        "enable_thinking": false
      }
    ],
    "default_profile": "write",
    "default_model": {
      "effort": "high",
      "provider": "copilot_chat",
      "model": "gpt-5.4"
    },
    "use_modifier_to_send": true
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "vim_mode": true,
  "vim": {
    "default_mode": "normal",
    "toggle_relative_line_numbers": true,
    "use_system_clipboard": "never"
  },
  "ui_font_size": 14.0,
  "buffer_font_size": 16.0,
  "cursor_blink": false,
  "format_on_save": "off",
  // "scroll_beyond_last_line": "off",
  // Allow the cursor to reach the edges of the screen
  "command_aliases": {
    "W": "w",
    "Wq": "wq",
    "Q": "q"
  },
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": false,
    "show_tab_bar_buttons": false,
    "show_nav_history_buttons": false,
    "show": true
  },
  "buffer_font_family": "JetBrains Mono",
  "theme": {
    "mode": "system",
    "light": "Vercel Light",
    "dark": "Gruvbox Dark Hard"
  },
  // "languages": {
  //   "PHP": {
  //     "language_servers": ["!phpactor", "intelephense", "..."],
  //     "formatter": {
  //       "external": {
  //         "command": "bunx",
  //         "arguments": ["prettier", "--stdin-filepath", "{buffer_path}"]
  //       }
  //     }
  //   }
  // },
  "file_types": {
    "MDX": ["*.mdx"],
    // "PHP": ["*.php"],
    "Blade": ["*blade.php"]
  },
  "languages": {
    "PHP": {
      "tab_size": 4,
      "hard_tabs": false,
      "formatter": {
        "external": {
          "command": "bash",
          "arguments": [
            "-c",
            "cat > {buffer_path} && ./vendor/bin/pint --quiet {buffer_path} && cat {buffer_path}"
          ]
        }
      },
      "language_servers": ["!phpactor", "intelephense", "..."]
    },
    "Blade": {
      "tab_size": 4,
      "hard_tabs": false,
      "language_servers": ["!phpactor", "intelephense", "..."]
    },
    "JavaScript": {
      "tab_size": 2,
      "format_on_save": "on"
    },
    "TypeScript": {
      "tab_size": 2,
      "format_on_save": "on"
    },
    "Vue": {
      "tab_size": 2,
      "format_on_save": "on"
    },
    "CSS": {
      "tab_size": 2,
      "format_on_save": "on"
    },
    "JSON": {
      "tab_size": 2,
      "format_on_save": "on"
    }
  },
  "lsp": {
    "mdx-analyzer": {
      "initialization_options": {
        "typescript": {
          "enabled": true
        }
      }
    },
    "intelephense": {
      "settings": {
        "intelephense.files.associations": ["*.php", "*.blade.php"],
        "intelephense.environment.phpVersion": "8.2.0",
        "intelephense.stubs": [
          "apache",
          "bcmath",
          "bz2",
          "calendar",
          "com_dotnet",
          "Core",
          "ctype",
          "curl",
          "date",
          "dba",
          "dom",
          "enchant",
          "exif",
          "FFI",
          "fileinfo",
          "filter",
          "fpm",
          "ftp",
          "gd",
          "gettext",
          "gmp",
          "hash",
          "iconv",
          "imap",
          "intl",
          "json",
          "ldap",
          "libxml",
          "mbstring",
          "meta",
          "mysqli",
          "oci8",
          "odbc",
          "openssl",
          "pcntl",
          "pcre",
          "PDO",
          "pdo_ibm",
          "pdo_mysql",
          "pdo_pgsql",
          "pdo_sqlite",
          "pgsql",
          "Phar",
          "posix",
          "pspell",
          "readline",
          "Reflection",
          "session",
          "shmop",
          "SimpleXML",
          "snmp",
          "soap",
          "sockets",
          "sodium",
          "SPL",
          "sqlite3",
          "standard",
          "superglobals",
          "sysvmsg",
          "sysvsem",
          "sysvshm",
          "tidy",
          "tokenizer",
          "xml",
          "xmlreader",
          "xmlrpc",
          "xmlwriter",
          "xsl",
          "Zend OPcache",
          "zip",
          "zlib"
        ]
      }
    }
  }
}
